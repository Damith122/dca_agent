# Copy this file's variable NAMES into Railway's Variables tab.
# Do not commit a real .env file with actual keys to GitHub.

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
USE_TESTNET=true
DRY_RUN=false
I_UNDERSTAND_THIS_IS_REAL_MONEY=yes

# --- Cloud-Sync Brain (optional) ---
# GITHUB_TOKEN / GITHUB_REPO enable cross-restart persistence of brain.pkl,
# trade logs, performance stats, and the trade-sync cursor.
# GITHUB_BRANCH defaults to "brain-state" - a DEDICATED branch, separate
# from the branch Railway deploys from (normally "main"). It is auto-created
# on first use. Do NOT set this to your deploy branch, or every runtime
# commit will trigger a Railway redeploy -> restart -> deploy loop.
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=your_username/your_repo
GITHUB_BRANCH=brain-state
